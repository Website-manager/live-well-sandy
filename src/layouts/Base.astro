---
// DS edit-loop validation 2026-06-27 — proves the managed-edit pipeline end to end (build-time only; no rendered change)
import '../styles/global.css';
import { getEntry } from 'astro:content';

interface Props {
  title: string;
  description: string;
  /** Which nav link is the current page — drives the active-state underline. */
  active?: 'home' | 'about' | 'contact';
}
const { title, description, active } = Astro.props;

// Footer + nav store link read from the editable contact + home content,
// so every page shares one source of truth for chrome.
const home = await getEntry('pages', 'home');
const contact = await getEntry('pages', 'contact');

const c = contact?.data ?? {};
const shopUrl = home?.data.cta_url ?? '#';
const shopLabel = home?.data.cta_label ?? 'Shop with me';
const location = c.location ?? 'Oak Ridge, Tennessee';
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Hanken+Grotesk:wght@400;500;600;700&family=Spline+Sans+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="bg-mesh" aria-hidden="true"></div>
  <div class="bg-grain" aria-hidden="true"></div>

  <!-- ===================== HEADER (shared chrome) ===================== -->
  <header id="site-header">
    <div class="wrap nav">
      <a class="brand" href="/" aria-label="Live Well, home">
        <span class="mark">Live Well</span>
        <span class="est">/ Est. {location}</span>
      </a>
      <nav class="nav-links" aria-label="Primary">
        <a href="/" class={active === 'home' ? 'is-active' : undefined} aria-current={active === 'home' ? 'page' : undefined}>Home</a>
        <a href="/about" class={active === 'about' ? 'is-active' : undefined} aria-current={active === 'about' ? 'page' : undefined}>About</a>
        <a href="/contact" class={active === 'contact' ? 'is-active' : undefined} aria-current={active === 'contact' ? 'page' : undefined}>Contact</a>
      </nav>
      <div class="nav-cta">
        <a class="btn btn-primary" href={shopUrl} target="_blank" rel="noopener noreferrer nofollow">
          {shopLabel} <span class="arr">→</span>
        </a>
        <button class="menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
          <svg class="ico ico-open" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg class="ico ico-close" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
        </button>
      </div>
    </div>
    <!-- Mobile nav drawer (revealed by the Menu button under 720px) -->
    <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile" hidden>
      <a href="/" class={active === 'home' ? 'is-active' : undefined} aria-current={active === 'home' ? 'page' : undefined}>Home</a>
      <a href="/about" class={active === 'about' ? 'is-active' : undefined} aria-current={active === 'about' ? 'page' : undefined}>About</a>
      <a href="/contact" class={active === 'contact' ? 'is-active' : undefined} aria-current={active === 'contact' ? 'page' : undefined}>Contact</a>
      <a class="m-shop" href={shopUrl} target="_blank" rel="noopener noreferrer nofollow">{shopLabel} <span class="arr">→</span></a>
    </nav>
  </header>

  <slot />

  <!-- ===================== FOOTER (shared chrome) ===================== -->
  <footer>
    <div class="wrap">
      <div class="foot-top">
        <div class="foot-brand">
          <div class="mark">Live Well</div>
          <p>Natural wellness, shared simply, by Sandy in {location}.</p>
          <a class="foot-shop" href={shopUrl} target="_blank" rel="noopener noreferrer nofollow">{shopLabel} <span class="arr">→</span></a>
        </div>
        <div class="foot-col">
          <h4>Explore</h4>
          <a href="/">Home</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </div>
        <div class="foot-col">
          <h4>Find me</h4>
          <span>{location}</span>
          {c.phone && <a href={`tel:${c.phone}`}>{c.phone}</a>}
          {c.email && <a href={`mailto:${c.email}`}>{c.email}</a>}
          {c.facebook_url && <a href={c.facebook_url} target="_blank" rel="noopener noreferrer">{c.facebook_label}</a>}
        </div>
      </div>
      <div class="foot-bottom">
        <p class="fine">© 2026 Live Wells Enterprises. &nbsp;·&nbsp; Wellness content is for
          educational purposes and is not intended to diagnose, treat, cure, or prevent any disease.
          Independent Wellness Advocate.</p>
      </div>
    </div>
  </footer>

  <script is:inline>
    // header background on scroll
    (function () {
      var header = document.getElementById('site-header');
      var onScroll = function () {
        if (window.scrollY > 24) header.classList.add('scrolled');
        else header.classList.remove('scrolled');
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // mobile menu toggle
      var toggle = document.querySelector('.menu-toggle');
      var drawer = document.getElementById('mobile-nav');
      if (toggle && drawer) {
        toggle.addEventListener('click', function () {
          var open = drawer.hasAttribute('hidden');
          if (open) { drawer.removeAttribute('hidden'); }
          else { drawer.setAttribute('hidden', ''); }
          toggle.setAttribute('aria-expanded', String(open));
          toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        });
      }

      // scroll-reveal
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var items = document.querySelectorAll('.reveal');
      if (reduce || !('IntersectionObserver' in window)) {
        items.forEach(function (el) { el.classList.add('in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });
      items.forEach(function (el) { io.observe(el); });
    })();
  </script>
</body>
</html>
