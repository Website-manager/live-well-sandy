---
import { getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';

const about = await getEntry('pages', 'about');
const contact = await getEntry('pages', 'contact');
const home = await getEntry('pages', 'home');

if (!about || !contact) {
  throw new Error('Missing required page content (about/contact).');
}

const a = about.data;
const c = contact.data;

// Render the About markdown body (the full story paragraphs).
const { Content: AboutStory } = await render(about);

const shopUrl = home?.data.cta_url ?? '#';
const shopLabel = home?.data.cta_label ?? 'Shop with me';

// "What matters to me" values — editable, with sensible defaults.
const values = [
  {
    title: a.about_value_1_title ?? 'Simple over complicated',
    body: a.about_value_1_body ?? 'I love products and routines that fit real life. Nothing fussy, nothing overwhelming.',
  },
  {
    title: a.about_value_2_title ?? 'Personal, not pushy',
    body: a.about_value_2_body ?? "I share what I genuinely use and enjoy, and I'm always happy to answer a question first.",
  },
  {
    title: a.about_value_3_title ?? 'Community first',
    body: a.about_value_3_body ?? "Most of the people I walk alongside are friends, family, and neighbors. I'd love for you to be one too.",
  },
];

const classesBody = a.classes_body ?? 'Online classes twice a month + a live workshop in my home each month (recorded and shared so no one misses out).';
---

<Base
  title="About Sandy — Live Well"
  description="Sandy's story: homeschool-books beginnings, Cherokee heritage, a full home of ten children and twenty-one grandchildren, and a love of music and natural wellness in Oak Ridge, Tennessee."
  active="about"
>
  <main id="top">
    <!-- ===================== ABOUT HERO ===================== -->
    <section class="page-hero about-hero">
      <div class="wrap about-hero-grid">
        <div class="about-hero-copy">
          <p class="eyebrow hero-tag load"><span class="tick">❋</span> {a.eyebrow}</p>
          <h1 class="display"><span class="word">Hi, I'm Sandy.</span></h1>
          <blockquote class="story-quote load">{a.quote}</blockquote>
          <div class="hero-actions load">
            <a class="btn btn-primary" href={shopUrl} target="_blank" rel="noopener noreferrer nofollow">{shopLabel} <span class="arr">→</span></a>
            <a class="btn btn-ghost" href="/contact">Say hello</a>
          </div>
        </div>
        <div class="about-hero-art load">
          <div class="story-art">
            <span class="corner c1"></span><span class="corner c2"></span><span class="corner c3"></span><span class="corner c4"></span>
            {a.story_image ? (
              <img class="story-photo" src={a.story_image} alt={`${a.sign_name ?? 'Sandy'}, your natural wellness guide`} />
            ) : (
              <svg aria-hidden="true" viewBox="0 0 200 240" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M100 226 C100 170 100 110 100 40"/>
                <path d="M100 80 C66 70 44 44 42 12 C78 18 102 44 100 80Z"/>
                <path d="M100 116 C134 106 156 80 158 48 C122 54 98 80 100 116Z"/>
                <path d="M100 152 C70 144 50 122 48 94 C80 100 102 124 100 152Z"/>
                <path d="M100 188 C130 180 150 158 152 130 C120 136 98 160 100 188Z"/>
                <circle cx="100" cy="30" r="7" fill="currentColor" stroke="none" opacity="0.85"/>
              </svg>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== STORY BODY ===================== -->
    <section class="story sec-pad" id="story">
      <div class="wrap story-layout">
        <div class="story-prose reveal">
          <p class="eyebrow" style="margin-bottom:1.5rem;"><span class="tick">❋</span> My story</p>
          <div class="prose">
            <AboutStory />
          </div>
          <div class="sign">{a.sign_name} <small>{a.sign_role}</small></div>
        </div>
        <aside class="story-aside reveal d2">
          <figure class="story-figure">
            <img src={a.story_aside_image ?? '/images/sandy-with-mom.jpg'} alt="Sandy and her mom together at the beach, both smiling in the sun" loading="lazy" />
            <figcaption>Family time means the world to me.</figcaption>
          </figure>
        </aside>
      </div>
    </section>

    <!-- ===================== WHAT MATTERS TO ME (dark pine) ===================== -->
    <section class="values sec-pad" id="matters">
      <div class="wrap">
        <div class="sec-head reveal">
          <p class="eyebrow"><span class="tick">❋</span> What matters to me</p>
          <h2 class="display">The values behind<br />everything I share.</h2>
        </div>
        <div class="value-grid">
          {values.map((v, i) => (
            <article class={`value reveal d${i + 1}`}>
              <div class="v-no">{String(i + 1).padStart(2, '0')}</div>
              <h3>{v.title}</h3>
              <p>{v.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== CLASSES & WORKSHOP ===================== -->
    <section class="sec-pad" id="classes" style="padding-block: clamp(2rem,4vh,4rem) clamp(4rem,9vh,7rem);">
      <div class="wrap">
        <div class="classes-panel reveal">
          <div class="classes-icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 14l18-8 18 8-18 8L6 14Z"/>
              <path d="M14 18v9c0 3 4.5 5 10 5s10-2 10-5v-9"/>
              <path d="M42 14v10"/>
            </svg>
          </div>
          <div class="classes-copy">
            <p class="eyebrow"><span class="tick">❋</span> Learn alongside me</p>
            <h2 class="display">Classes & a monthly workshop.</h2>
            <p>{classesBody}</p>
            <a class="text-link" href="/contact">Ask me about the next one <span class="arr">→</span></a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
