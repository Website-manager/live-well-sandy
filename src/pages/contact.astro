---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import { KIT_FORM_ACTION } from '../lib/site';

const contact = await getEntry('pages', 'contact');
const home = await getEntry('pages', 'home');

if (!contact) {
  throw new Error('Missing required page content (contact).');
}

const c = contact.data;
const shopUrl = home?.data.cta_url ?? '#';
const shopLabel = home?.data.cta_label ?? 'Shop with me';

// Editable contact-page intro, with defaults.
const heading = c.contact_heading ?? "Let's stay in touch";
const intro = c.contact_intro ?? "Have a question, or want my current specials in your inbox? Reach out or sign up below. I'd love to hear from you and help however I can.";
---

<Base
  title="Contact Sandy — Live Well"
  description="Get in touch with Sandy. Email, phone, or join the Live Well Team on Facebook — based in Oak Ridge, Tennessee."
  active="contact"
>
  <main id="top">
    <!-- ===================== CONTACT HERO ===================== -->
    <section class="page-hero contact-hero">
      <div class="wrap">
        <div class="contact-hero-copy">
          <p class="eyebrow hero-tag load"><span class="tick">❋</span> Reach out anytime</p>
          <h1 class="display"><span class="word">{heading}</span></h1>
          <p class="lede load">{intro}</p>
        </div>
      </div>
    </section>

    <!-- ===================== CONTACT DETAILS ===================== -->
    <section class="contact-section sec-pad" id="details" style="padding-top: clamp(1rem,3vh,2.5rem);">
      <div class="wrap">
        <div class="contact-grid">
          {c.email && (
            <a class="contact-card reveal d1" href={`mailto:${c.email}`}>
              <span class="cc-ico" aria-hidden="true">
                <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="9" width="30" height="22" rx="3"/><path d="M6 11l14 11L34 11"/></svg>
              </span>
              <span class="cc-label">Email</span>
              <span class="cc-value">{c.email}</span>
            </a>
          )}
          {c.phone && (
            <a class="contact-card reveal d2" href={`tel:${c.phone}`}>
              <span class="cc-ico" aria-hidden="true">
                <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6l4 1 2 7-3 2c1 4 4 7 8 8l2-3 7 2 1 4c0 2-2 4-4 4C18 31 9 22 8 12c0-2 2-4 4-6Z"/></svg>
              </span>
              <span class="cc-label">Phone</span>
              <span class="cc-value">{c.phone}</span>
            </a>
          )}
          <div class="contact-card is-static reveal d3">
            <span class="cc-ico" aria-hidden="true">
              <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 35c7-7 11-12 11-18a11 11 0 1 0-22 0c0 6 4 11 11 18Z"/><circle cx="20" cy="17" r="4"/></svg>
            </span>
            <span class="cc-label">Where I am</span>
            <span class="cc-value">{c.location}</span>
          </div>
          {c.facebook_url && (
            <a class="contact-card reveal d1" href={c.facebook_url} target="_blank" rel="noopener noreferrer">
              <span class="cc-ico" aria-hidden="true">
                <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M24 13h4V8h-4c-4 0-6 2-6 6v3h-4v5h4v12h5V22h4l1-5h-5v-2c0-1 .5-2 1-2Z"/></svg>
              </span>
              <span class="cc-label">Facebook</span>
              <span class="cc-value">{c.facebook_label}</span>
            </a>
          )}
        </div>
      </div>
    </section>

    <!-- ===================== NEWSLETTER SIGNUP ===================== -->
    <section class="sec-pad" id="join" style="padding-block: clamp(1rem,3vh,3rem) clamp(4rem,9vh,7rem);">
      <div class="wrap">
        <div class="signup-panel reveal">
          <div class="glow" aria-hidden="true"></div>
          <div class="signup-inner">
            <div>
              <p class="eyebrow" style="color:var(--seaglass-lt)"><span class="tick" style="color:var(--spring)">❋</span> The Live Well note</p>
              <h2 class="display">Get my specials in your inbox.</h2>
              <p>One friendly note now and then with the products and ideas I'm loving. No noise — just the good stuff, and you can unsubscribe anytime.</p>
            </div>
            {KIT_FORM_ACTION ? (
              <!-- Live Kit (ConvertKit) signup — posts straight to Kit, no widget. -->
              <form class="signup-form" action={KIT_FORM_ACTION} method="post" aria-describedby="signup-note">
                <label for="email" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);">Email address</label>
                <input id="email" name="email_address" type="email" required placeholder="you@example.com" autocomplete="email" />
                <button class="btn btn-spring" type="submit">Join <span class="arr">→</span></button>
                <p id="signup-note" class="signup-fine" style="flex-basis:100%;">One friendly note now and then. Unsubscribe anytime.</p>
              </form>
            ) : (
              <!-- Fallback until Sandy's Kit Form ID is set in src/lib/site.ts. -->
              <form class="signup-form" onsubmit="return false;" aria-describedby="signup-note">
                <label for="email" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);">Email address</label>
                <input id="email" type="email" placeholder="you@example.com" autocomplete="email" />
                <button class="btn btn-spring" type="submit">Join <span class="arr">→</span></button>
                <p id="signup-note" class="signup-fine" style="flex-basis:100%;">Sign-up is coming soon — for now, just email me and I'll add you myself.</p>
              </form>
            )}
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
