---
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';

// ---- editable content, pulled from files (Content Layer / Pages CMS) ----
const home = await getEntry('pages', 'home');
const about = await getEntry('pages', 'about');
const contact = await getEntry('pages', 'contact');

if (!home || !about || !contact) {
  throw new Error('Missing required page content (home/about/contact).');
}

const h = home.data;
const a = about.data;
const c = contact.data;

// Specials — published only, ordered ascending. This is the section Sandy edits.
const specials = (await getCollection('specials', ({ data }) => data.published))
  .sort((x, y) => x.data.order - y.data.order);
const specialContents = await Promise.all(specials.map((s) => render(s)));

// Single source for the shop link/label.
const shopUrl = h.cta_url ?? '#';
const shopLabel = h.cta_label ?? 'Shop with me';

// The three "Why work with me" values are editable, with sensible defaults.
const values = [
  {
    title: h.value_1_title ?? 'Products I personally love',
    body: h.value_1_body ?? 'I share what I reach for in my own home, with simple ideas for making them part of an everyday routine.',
  },
  {
    title: h.value_2_title ?? 'A real person to ask',
    body: h.value_2_body ?? "Curious before you try something? Reach out anytime. I'm happy to be your guide and answer your questions.",
  },
  {
    title: h.value_3_title ?? 'Learn right alongside me',
    body: h.value_3_body ?? "I host online classes twice a month and a workshop in my home, so there's always a friendly place to learn together.",
  },
];
---

<Base
  title="Live Well — Natural wellness, shared simply"
  description="Natural wellness, shared simply. Sandy helps everyday people bring a little more calm and care into their routines, from Oak Ridge, Tennessee."
  active="home"
>
  <main id="top">
    <!-- ===================== HERO ===================== -->
    <section class="hero">
      <div class="wrap hero-grid">
        <div class="hero-copy">
          <p class="eyebrow hero-tag load"><span class="tick">❋</span> {h.eyebrow}</p>
          <h1 class="display">
            <span class="word" style="animation-delay:.12s">{h.title}</span>
          </h1>
          <p class="lede load">{h.intro}</p>
          <div class="hero-actions load">
            <a class="btn btn-primary" href={shopUrl} target="_blank" rel="noopener noreferrer nofollow">{shopLabel} <span class="arr">→</span></a>
            <a class="btn btn-ghost" href="/about">Read my story</a>
          </div>
          <div class="hero-meta load">
            <div><div class="m-num">{h.stat_1_value}</div><div class="m-lab">{h.stat_1_label}</div></div>
            <div><div class="m-num">{h.stat_2_value}</div><div class="m-lab">{h.stat_2_label}</div></div>
            <div><div class="m-num">{h.stat_3_value}</div><div class="m-lab">{h.stat_3_label}</div></div>
          </div>
        </div>

        <div class="hero-art load">
          <div class="art-frame">
            {h.hero_image ? (
              <img
                class="hero-photo"
                src={h.hero_image}
                alt={`${a.sign_name ?? 'Sandy'}, natural wellness guide in ${c.location}`}
              />
            ) : (
              <>
                <div class="veil" aria-hidden="true"></div>
                <div class="art-botanical" aria-hidden="true">
                  <svg viewBox="0 0 200 280" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M100 268 C100 210 100 150 100 60" />
                    <path d="M100 96 C72 84 52 60 50 30 C82 36 100 60 100 96 Z" fill="rgba(238,241,236,0.10)"/>
                    <path d="M100 128 C128 116 148 92 150 62 C118 68 100 92 100 128 Z" fill="rgba(238,241,236,0.10)"/>
                    <path d="M100 160 C74 150 56 128 54 100 C84 106 100 130 100 160 Z" fill="rgba(238,241,236,0.08)"/>
                    <path d="M100 192 C126 182 144 160 146 132 C116 138 100 162 100 192 Z" fill="rgba(238,241,236,0.08)"/>
                    <circle cx="100" cy="50" r="9" fill="rgba(140,207,87,0.9)" stroke="none"/>
                    <path d="M86 230 C70 228 58 218 56 204 M114 230 C130 228 142 218 144 204" />
                  </svg>
                </div>
                <div class="grain2" aria-hidden="true"></div>
              </>
            )}
          </div>
          <div class="art-label load">
            <span class="l-no">Oak Ridge · Tennessee</span>
            <span class="l-name">Hi, I'm Sandy</span>
            <span class="l-sub">your friendly wellness guide</span>
          </div>
        </div>
      </div>
      <span class="vrun load" aria-hidden="true">Natural wellness · Oak Ridge, Tennessee</span>
    </section>

    <!-- ===================== WELCOME / "Hi, I'm Sandy" ===================== -->
    <section class="welcome sec-pad" id="welcome">
      <div class="wrap welcome-grid">
        <div class="welcome-art reveal">
          <span class="corner c1"></span><span class="corner c2"></span><span class="corner c3"></span><span class="corner c4"></span>
          <img class="welcome-photo" src="/images/sandy-about.webp" alt="Sandy smiling on the beach on a bright, breezy day" loading="lazy" />
        </div>
        <div class="welcome-copy reveal d2">
          <p class="eyebrow"><span class="tick">❋</span> A warm hello</p>
          <h2 class="display">Hi, I'm Sandy.</h2>
          <p>I live in Oak Ridge, Tennessee, where I share natural products I love with my friends, family, and neighbors. With ten children and twenty-one grandchildren, my home stays full and joyful.</p>
          <p>I'm also a musician who loves to sing and direct choirs, and I treasure being a friendly guide for anyone curious about natural wellness.</p>
          <a class="text-link" href="/about">More about me <span class="arr">→</span></a>
        </div>
      </div>
    </section>

    <!-- ===================== WHY WORK WITH ME (dark pine) ===================== -->
    <section class="values sec-pad" id="why">
      <div class="wrap">
        <div class="sec-head reveal">
          <p class="eyebrow"><span class="tick">❋</span> Why work with me</p>
          <h2 class="display">Simple, personal,<br />and never pushy.</h2>
        </div>
        <div class="value-grid">
          {values.map((v, i) => (
            <article class={`value reveal d${i + 1}`}>
              <div class="v-no">{String(i + 1).padStart(2, '0')}</div>
              <h3>{v.title}</h3>
              <p>{v.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== THIS SEASON / SPECIALS ===================== -->
    <section class="season sec-pad" id="season">
      <div class="wrap">
        <div class="sec-head reveal">
          <div class="h-left">
            <p class="eyebrow"><span class="tick">❋</span> This season</p>
            <h2 class="display">A few favorites I'm loving now.</h2>
          </div>
          <a class="btn btn-ghost" href={shopUrl} target="_blank" rel="noopener noreferrer nofollow">See my full shop <span class="arr">→</span></a>
        </div>
        <div class="feature-grid">
          {specials.map((special, i) => {
            const { Content: Description } = specialContents[i];
            const offset = i % 2 === 1;
            return (
              <article class={`feature reveal ${i % 2 === 0 ? 'd1' : 'd2'}${offset ? ' offset' : ''}`}>
                {special.data.product_image ? (
                  <div class="feature-art">
                    <img
                      class="feature-photo"
                      src={special.data.product_image}
                      alt={special.data.title}
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class="feature-art" aria-hidden="true">
                    {i % 2 === 0 ? (
                      <svg viewBox="0 0 120 160" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="40" y="6" width="40" height="16" rx="3"/>
                        <path d="M44 22h32v10c14 6 22 18 22 36v66a12 12 0 0 1-12 12H34a12 12 0 0 1-12-12V68c0-18 8-30 22-36V22Z" fill="rgba(238,241,236,0.08)"/>
                        <path d="M34 96h52" stroke-width="2" opacity="0.6"/>
                        <circle cx="60" cy="118" r="14" stroke-width="2" opacity="0.7"/>
                        <path d="M60 110v16M52 118h16" stroke-width="2" opacity="0.7"/>
                      </svg>
                    ) : (
                      <svg viewBox="0 0 120 160" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M60 12c-3 8-3 14 0 20M60 12c3 8 3 14 0 20"/>
                        <path d="M60 150 C60 110 60 70 60 36"/>
                        <path d="M60 64 C40 56 28 40 26 20 C50 24 62 42 60 64Z" fill="rgba(238,241,236,0.10)"/>
                        <path d="M60 92 C80 84 92 68 94 48 C70 52 58 70 60 92Z" fill="rgba(238,241,236,0.10)"/>
                        <path d="M60 120 C42 114 32 100 30 84 C52 88 62 104 60 120Z" fill="rgba(238,241,236,0.08)"/>
                      </svg>
                    )}
                  </div>
                )}
                <div class="feature-body">
                  <span class="f-no">{special.data.label}</span>
                  <h3>{special.data.title}</h3>
                  <Description />
                  <a class="shop" href={special.data.shop_url} target="_blank" rel="noopener noreferrer nofollow">Shop this <span class="arr">→</span></a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ===================== SHOP CTA ===================== -->
    <section class="sec-pad" id="shop" style="padding-block: clamp(2rem,4vh,4rem) clamp(4rem,9vh,7rem);">
      <div class="wrap">
        <div class="cta-panel reveal">
          <div class="glow" aria-hidden="true"></div>
          <div class="cta-art" aria-hidden="true">
            <img src={h.featured_image ?? '/images/oil-bottle.jpg'} alt="" loading="lazy" />
          </div>
          <div class="cta-inner">
            <p class="eyebrow" style="color:var(--seaglass-lt)"><span class="tick" style="color:var(--spring)">❋</span> Ready to start?</p>
            <h2 class="display">Find what feels right for you.</h2>
            <p>Browse the products I personally use and love. If you'd like a friendly hand choosing, I'm only a message away.</p>
            <a class="btn btn-spring" href={shopUrl} target="_blank" rel="noopener noreferrer nofollow">{shopLabel} <span class="arr">→</span></a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
